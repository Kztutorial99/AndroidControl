# Salin file ini menjadi .env lalu isi nilainya
# cp .env.example .env

# ── Database (WAJIB) ──────────────────────────────────────────────────────
# Jika pakai Docker Compose (self-hosted):
DATABASE_URL=postgresql://android_user:ganti_password_ini@localhost:5432/androidconnector

# Jika pakai server PostgreSQL sendiri:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# ── Password database untuk Docker Compose ───────────────────────────────
DB_PASSWORD=ganti_password_ini
