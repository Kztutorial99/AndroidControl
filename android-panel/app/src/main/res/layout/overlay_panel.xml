<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BUBBLE STATE -->
    <LinearLayout
        android:id="@+id/bubbleView"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:background="@drawable/bubble_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IWX"
            android:textColor="#000000"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textColor="#000000"
            android:textSize="7sp" />
    </LinearLayout>

    <!-- PANEL STATE -->
    <LinearLayout
        android:id="@+id/panelView"
        android:layout_width="340dp"
        android:layout_height="520dp"
        android:background="@drawable/panel_bg"
        android:orientation="vertical"
        android:elevation="16dp"
        android:visibility="gone">

        <!-- Drag Handle Bar -->
        <LinearLayout
            android:id="@+id/dragHandle"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="#161b22"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⠿  IWX PANEL"
                android:textColor="#00c853"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Minimize to bubble -->
            <TextView
                android:id="@+id/btnMinimize"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="─"
                android:textColor="#8b949e"
                android:textSize="14sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <!-- Close overlay -->
            <TextView
                android:id="@+id/btnClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="#f85149"
                android:textSize="14sp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- WebView -->
        <WebView
            android:id="@+id/overlayWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>
</FrameLayout>
